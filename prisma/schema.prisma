generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  MASTER
}

enum TermType {
  USER
  ADMIN
}

enum EcoCoinTransactionType {
  CREDIT
  REDEMPTION
  REFUND
}

enum RedemptionStatus {
  PENDING
  COMPLETED
  EXPIRED
}

model User {
  id                         String                   @id @default(uuid())
  name                       String
  cpf                        String
  cpfHash                    String?                  @unique
  birthDate                  String
  phone                      String
  cep                        String
  address                    String
  city                       String
  state                      String
  profilePhoto               String?
  termsAccepted              Boolean                  @default(false)
  email                      String
  emailHash                  String?                  @unique
  password                   String
  role                       Role                     @default(USER)
  active                     Boolean                  @default(true)
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  termAccepts                TermAccept[]
  sessions                   Session[]
  twoFactorChallenges        TwoFactorChallenge[]
  passwordResetChallenges    PasswordResetChallenge[]
  ecoCoinBalance             Decimal                  @default(0) @db.Decimal(12, 2)
  products                   Product[]                @relation("AdminProducts")
  redemptions                Redemption[]             @relation("UserRedemptions")
  validatedRedemptions       Redemption[]             @relation("ValidatedRedemptions")
  ecoCoinTransactions        EcoCoinTransaction[]     @relation("UserEcoCoinTransactions")
  grantedEcoCoinTransactions EcoCoinTransaction[]     @relation("GrantedEcoCoinTransactions")

  @@map("users")
}

model Product {
  id          String       @id @default(uuid())
  adminId     String
  name        String
  description String
  photo       String
  price       Decimal      @db.Decimal(12, 2)
  quantity    Int
  city        String
  state       String
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  admin       User         @relation("AdminProducts", fields: [adminId], references: [id])
  redemptions Redemption[]

  @@index([city, state, active])
  @@index([adminId])
  @@map("products")
}

model Redemption {
  id            String           @id @default(uuid())
  userId        String
  productId     String
  quantity      Int
  unitPrice     Decimal          @db.Decimal(12, 2)
  totalPrice    Decimal          @db.Decimal(12, 2)
  pickupCode    String?          @unique
  status        RedemptionStatus @default(PENDING)
  expiresAt     DateTime
  completedAt   DateTime?
  validatedById String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation("UserRedemptions", fields: [userId], references: [id])
  product       Product          @relation(fields: [productId], references: [id])
  validatedBy   User?            @relation("ValidatedRedemptions", fields: [validatedById], references: [id])

  @@index([userId, status])
  @@index([productId, status])
  @@index([status, expiresAt])
  @@map("redemptions")
}

model EcoCoinTransaction {
  id           String                 @id @default(uuid())
  userId       String
  grantedById  String?
  redemptionId String?
  type         EcoCoinTransactionType
  amount       Decimal                @db.Decimal(12, 2)
  description  String?
  createdAt    DateTime               @default(now())
  user         User                   @relation("UserEcoCoinTransactions", fields: [userId], references: [id])
  grantedBy    User?                  @relation("GrantedEcoCoinTransactions", fields: [grantedById], references: [id])

  @@index([userId, createdAt])
  @@index([redemptionId])
  @@map("eco_coin_transactions")
}

model PasswordResetChallenge {
  id                  String    @id @default(uuid())
  userId              String
  codeHash            String
  codeSalt            String
  attempts            Int       @default(0)
  blockedUntil        DateTime?
  verifiedAt          DateTime?
  resetTokenHash      String?
  resetTokenSalt      String?
  resetTokenExpiresAt DateTime?
  consumedAt          DateTime?
  expiresAt           DateTime
  createdAt           DateTime  @default(now())
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([blockedUntil])
  @@map("password_reset_challenges")
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model TwoFactorChallenge {
  id         String    @id @default(uuid())
  userId     String
  codeHash   String
  codeSalt   String
  attempts   Int       @default(0)
  consumedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("two_factor_challenges")
}

model Term {
  id         String       @id @default(uuid())
  documentId String       @unique @default(uuid())
  title      String?
  text       String
  type       TermType
  version    Int
  active     Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  accepts    TermAccept[]

  @@unique([type, version])
  @@index([type, active])
  @@map("terms")
}

model TermAccept {
  id         String   @id @default(uuid())
  userId     String
  termId     String
  accepted   Boolean  @default(true)
  acceptedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  term       Term     @relation(fields: [termId], references: [id])

  @@unique([userId, termId])
  @@index([userId])
  @@index([termId])
  @@map("term_accepts")
}
